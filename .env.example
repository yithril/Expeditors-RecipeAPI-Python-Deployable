# Copy to .env and fill in your PostgreSQL connection details.
# Azure Flexible Server: use the connection string from the portal and add ?sslmode=require

DB_URL=postgresql://user:password@your-server.postgres.database.azure.com:5432/recipes?sslmode=require

# Or build the URL from parts (used when DB_URL is empty):
# DB_HOST=your-server.postgres.database.azure.com
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
# DB_NAME=recipes
# DB_PORT=5432

# Optional: separate database for pytest (falls back to DB_URL if unset)
# TEST_DB_URL=postgresql://user:password@your-server.postgres.database.azure.com:5432/recipes_test?sslmode=require

FLASK_DEBUG=1
FLASK_APP=app
